# 基金管理系统 - 环境变量配置
# 复制此文件为 .env 并修改配置

# ============================================
# Docker 部署配置
# ============================================

# 数据目录挂载路径（Docker 部署时使用）
# 默认: ./data (项目目录下的 data 文件夹)
# 生产环境示例: /home/user/fund_data
DATA_PATH=./data

# ============================================
# 安全相关（必填）
# ============================================

# JWT 密钥 - 生产环境务必修改！
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# 数据库配置
# ============================================

# SQLite 数据库路径
# 默认保存在项目目录的 data/ 文件夹下
DATABASE_URL=sqlite:///./data/fund_manager.db

# ============================================
# 认证配置
# ============================================

# JWT Token 有效期（天）
ACCESS_TOKEN_EXPIRE_DAYS=7

# JWT 算法
ALGORITHM=HS256
